{
  "name": "ohno",
  "version": "0.0.0",
  "description": "Interactive Angular playground for learning algorithms and data structures.",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:algorithms": "vitest run --config vitest.config.ts",
    "test:algorithms:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:algorithms:watch": "vitest --config vitest.config.ts",
    "verify": "npm run test:algorithms && npm run build",
    "verify:quick": "npm run build",
    "deploy:production": "git push origin main:production",
    "release:production": "npm run verify && npm run deploy:production",
    "i18n:extract": "transloco-keys-manager extract",
    "i18n:find": "transloco-keys-manager find"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0",
    "npm": ">=10"
  },
  "dependencies": {
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/pro-duotone-svg-icons": "^7.2.0",
    "@fortawesome/pro-light-svg-icons": "^7.2.0",
    "@fortawesome/pro-regular-svg-icons": "^7.2.0",
    "@fortawesome/pro-solid-svg-icons": "^7.2.0",
    "@fortawesome/pro-thin-svg-icons": "^7.2.0",
    "@fortawesome/sharp-light-svg-icons": "^7.2.0",
    "@fortawesome/sharp-regular-svg-icons": "^7.2.0",
    "@fortawesome/sharp-solid-svg-icons": "^7.2.0",
    "@fortawesome/sharp-thin-svg-icons": "^7.2.0",
    "@jsverse/transloco": "^8.3.0",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "animejs": "^4.3.6",
    "d3": "^7.9.0",
    "katex": "^0.16.45",
    "rxjs": "~7.8.0",
    "shiki": "^4.0.2",
    "three": "^0.184.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.9",
    "@jsverse/transloco-keys-manager": "^8.1.0",
    "@types/animejs": "^3.1.13",
    "@types/d3": "^7.4.3",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.8"
  }
}
